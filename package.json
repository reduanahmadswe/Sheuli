{
  "name": "sheuli",
  "version": "1.0.0",
  "description": "Sheuli — WhatsApp AI Auto-Reply Assistant. She blooms while you sleep.",
  "type": "module",
  "private": true,
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "dashboard:dev": "npm run dev --prefix dashboard",
    "dashboard:build": "npm run build --prefix dashboard",
    "install:all": "npm install && npm install --prefix dashboard",
    "postinstall": "npx puppeteer browsers install chrome",
    "build": "npm run dashboard:build",
    "setup": "npm run install:all && npm run build"
  },
  "keywords": ["whatsapp", "ai", "bot", "sheuli", "openai", "assistant"],
  "author": "Reduan",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "cookie": "^0.7.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "openai": "^4.79.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "socket.io": "^4.8.1",
    "whatsapp-web.js": "^1.26.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
