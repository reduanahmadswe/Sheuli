# ─── Sheuli configuration ───────────────────────────────────────────────
# Copy this file to .env and fill in your own values. Never commit .env.

# OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Password to log into the Sheuli web dashboard (choose something strong,
# this dashboard will be reachable from the internet once deployed).
DASHBOARD_PASSWORD=

# Secret used to sign the dashboard's session cookie. Any long random string.
SESSION_SECRET=change-this-to-a-long-random-string

# Port the Express server (API + dashboard) listens on.
PORT=3000

# Default timezone used for schedule mode.
TIMEZONE=Asia/Dhaka

# Your name, used in the AI system prompt.
OWNER_NAME=Reduan
