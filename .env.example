# ─── Sheuli configuration ───────────────────────────────────────────────
# Copy this file to .env and fill in your own values. Never commit .env.

# OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Password to log into the Sheuli web dashboard (choose something strong,
# this dashboard will be reachable from the internet once deployed).
DASHBOARD_PASSWORD=

# Secret used to sign the dashboard's session cookie. Any long random string.
SESSION_SECRET=change-this-to-a-long-random-string

# Port the Express server (API + dashboard) listens on.
# On Railway this is injected automatically — leave it unset there.
PORT=3000

# Where persistent data (SQLite DB, WhatsApp session, backups, file logs)
# lives. Leave EMPTY for local dev — it defaults to the project root, so
# nothing extra to set up. Only set this in production containers where a
# persistent Volume is mounted, e.g. on Railway: STORAGE_DIR=/app/storage
STORAGE_DIR=

# Default timezone used for schedule mode.
TIMEZONE=Asia/Dhaka

# Your name, used in the AI system prompt.
OWNER_NAME=Reduan

# ─── Telegram alerts (optional) ─────────────────────────────────────────
# Leave both empty to disable alerting entirely — everything else still works.
# See the README's "Telegram alerts" section for how to create a bot with
# @BotFather and find your chat ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Daily SQLite backup time (24h HH:MM, in TIMEZONE above). Defaults to 03:00.
BACKUP_TIME=03:00
